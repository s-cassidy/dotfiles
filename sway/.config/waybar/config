            "warning": 25,
            "critical": 10
        },
        "tooltip": false
    },
    "pulseaudio": {
        "format": "{volume} {icon} ",
        "format-alt": "{volume} {icon} ",
        "format-alt-click": "click-right",
        "format-muted": "´Üę",
        "format-icons": {
            "headphones": "´Çą",
            "handsfree": "´ľÉ",
            "headset": "´ľÉ",
            "phone": "´éĽ",
